@model BSS_WEB.Views.Reconcilation.Reconsile.IndexModel
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	ViewData["Title"] = "Reconciliation";
}

<link rel="stylesheet" href="@Url.Content("~/css/master/all.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/reconsile/reconsileTransaction.css")" asp-append-version="true" />
@if (Model.CssVariantClass == "reconsile-unsort-cc") {
	<link rel="stylesheet" href="@Url.Content("~/css/reconsile/reconsile-unsort-cc.css")" asp-append-version="true" />
} else if (Model.CssVariantClass == "reconsile-ca-member") {
	<link rel="stylesheet" href="@Url.Content("~/css/reconsile/reconsile-ca-member.css")" asp-append-version="true" />
} else if (Model.CssVariantClass == "reconsile-ca-non-member") {
	<link rel="stylesheet" href="@Url.Content("~/css/reconsile/reconsile-ca-non-member.css")" asp-append-version="true" />
}

<input type="hidden" id="currentUserId" value="@User.FindFirst("UserID")?.Value" />
<input type="hidden" id="currentUserFullName" value="@( (User.FindFirst("FirstName")?.Value ?? "") + " " + (User.FindFirst("Lastname")?.Value ?? "") )" />
<input type="hidden" id="currentDepartmentId" value="@(User.FindFirst("DepartmentID")?.Value ?? User.FindFirst("DepartmentId")?.Value)" />
<input type="hidden" id="cssVariantClass" value="@Model.CssVariantClass" />
<input type="hidden" id="bnTypeCode" value="@Model.BnTypeCode" />
<input type="hidden" id="reconsileTranId" value="@Model.ReconsileTranId" />

<!-- ============================================================
     PAGE LAYOUT (from Figma 1:18004)
     ============================================================ -->
<div class="reconsile-layout">

	<!-- Title -->
	<div class="reconsile-title">
		<h1>@Model.BnTypeNameDisplay</h1>
	</div>

	<!-- Main Content -->
	<div class="reconsile-main">

		<!-- ====================================================
		     TOP PANEL: Info Card + 2-Column Split
		     ==================================================== -->
		<div class="reconsile-top-panel">

			<!-- Info Card Bar -->
			<div class="reconsile-info-card">
				<div class="reconsile-info-row">
					<div class="reconsile-info-item">
						<span class="reconsile-info-label">Header Card:</span>
						<span class="reconsile-info-value reconsile-info-badge" id="infoHeaderCard"></span>
						<input type="text" id="childHcInput" class="reconsile-info-value reconsile-info-badge"
							   style="display:none; outline:none; width:152px;" />
					</div>
					<div class="reconsile-info-item">
						<span class="reconsile-info-label">จำนวนมัด/Header Card:</span>
						<span class="reconsile-info-value warning" id="infoBundleCount">0</span>
					</div>
					<div class="reconsile-info-item">
						<span class="reconsile-info-label">Date/Time:</span>
						<span class="reconsile-info-value bold" id="infoDateTime">-</span>
					</div>
				</div>
			</div>

			<!-- 2-Column Split -->
			<div class="reconsile-split">

				<!-- LEFT: Small Denomination Table -->
				<div class="reconsile-split-left">
					<div class="reconsile-denom-table-wrapper">
						<div class="reconsile-denom-table-scroll">
							<table class="reconsile-denom-table">
								<thead>
									<tr>
										<th class="col-hc th-sort" data-sort="headerCard">Header Card <i class="bi bi-chevron-expand sort-icon"></i></th>
										<th class="col-denom th-sort" data-sort="denom">ชนิดราคา <i class="bi bi-chevron-expand sort-icon"></i></th>
										<th class="col-bank th-sort" data-sort="bank">ธนาคาร <i class="bi bi-chevron-expand sort-icon"></i></th>
										<th class="col-cashpoint th-sort" data-sort="cashpoint">Cashpoint <i class="bi bi-chevron-expand sort-icon"></i></th>
										<th class="col-bundle th-sort" data-sort="bundle">จำนวนมัด <i class="bi bi-chevron-expand sort-icon"></i></th>
									</tr>
								</thead>
								<tbody id="denomTableBody">
									<!-- Populated by JS -->
								</tbody>
							</table>
						</div>
					</div>
				</div>

				<!-- RIGHT: Input Form -->
				<div class="reconsile-split-right">
					<div class="reconsile-input-form">

						<!-- ประเภทธนบัตร (Banknote Type) + หมายเหตุ — two-column row per Figma 51:78706 -->
						<div class="reconsile-banknote-row">
							<div class="reconsile-form-group">
								<span class="reconsile-form-label">ประเภทธนบัตร</span>
								<div class="reconsile-radio-group" id="banknoteTypeGroup">
									<label class="reconsile-radio-item selected">
										<input type="radio" name="banknoteType" value="reject" checked />
										<span>Reject</span>
									</label>
									<label class="reconsile-radio-item">
										<input type="radio" name="banknoteType" value="counterfeit" />
										<span>ปลอม</span>
									</label>
									<label class="reconsile-radio-item">
										<input type="radio" name="banknoteType" value="damaged" />
										<span>ชำรุด</span>
									</label>
								</div>
							</div>
							<!-- หมายเหตุ — แสดงเมื่อเลือก ปลอม หรือ ชำรุด -->
							<div class="reconsile-remark-col" id="remarkGroup" style="display: none;">
								<label class="reconsile-remark-label">หมายเหตุ</label>
								<input type="text" id="inputRemark" class="reconsile-remark-input" placeholder="" />
							</div>
						</div>

						<!-- ชนิดราคา (Denomination) -->
						<div class="reconsile-form-group">
							<span class="reconsile-form-label">ชนิดราคา</span>
							<div class="reconsile-denom-chips" id="denomChipsGroup">
								<label class="reconsile-denom-chip denom-1000 selected">
									<input type="radio" name="denomValue" value="1000" checked />
									<span class="denom-badge">1000</span>
								</label>
								<label class="reconsile-denom-chip denom-500">
									<input type="radio" name="denomValue" value="500" />
									<span class="denom-badge">500</span>
								</label>
								<label class="reconsile-denom-chip denom-100">
									<input type="radio" name="denomValue" value="100" />
									<span class="denom-badge">100</span>
								</label>
								<label class="reconsile-denom-chip denom-50">
									<input type="radio" name="denomValue" value="50" />
									<span class="denom-badge">50</span>
								</label>
								<label class="reconsile-denom-chip denom-20">
									<input type="radio" name="denomValue" value="20" />
									<span class="denom-badge">20</span>
								</label>
							</div>
						</div>

						<!-- แบบ + จำนวน -->
						<div class="reconsile-fields-row">
							<div class="reconsile-field">
								<label>แบบ</label>
								<select id="selectType">
									<option value="17">17</option>
									<option value="16">16</option>
									<option value="15">15</option>
									<option value="99">99</option>
								</select>
							</div>
							<div class="reconsile-field">
								<label>จำนวน</label>
								<input type="number" id="inputQuantity" value="" min="1" max="1000" step="1" placeholder="" />
							</div>
						</div>

						<!-- บันทึกตารางสรุปยอด -->
						<button type="button" class="reconsile-btn-save-summary" id="btnSaveToSummary">
							<i class="bi bi-chevron-double-down"></i>
							บันทึกตารางสรุปยอด
							<i class="bi bi-chevron-double-down"></i>
						</button>

					</div>
				</div>
			</div>
		</div>

		<!-- ====================================================
		     SUMMARY TABLE (ตารางสรุปยอด)
		     ==================================================== -->
		<div class="reconsile-summary-wrapper">
			<div class="reconsile-summary-title">ตารางสรุปยอด</div>
			<div class="reconsile-summary-scroll">
				<table class="reconsile-summary-table">
					<thead>
						<tr>
							<th class="col-hc th-sort" data-sort="headerCard">Header Card <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-time th-sort" data-sort="time">เวลานับคัด <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-denom th-sort" data-sort="denom">ชนิดราคา <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-type th-sort" data-sort="type">แบบ <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-category th-sort" data-sort="category">ประเภท <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-qty th-sort" data-sort="qty">จำนวน (ฉบับ) <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-value th-sort" data-sort="value">มูลค่า (บาท) <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-remark th-sort" data-sort="remark">หมายเหตุ <i class="bi bi-chevron-expand sort-icon"></i></th>
							<th class="col-action">Action</th>
						</tr>
					</thead>
					<tbody id="summaryTableBody">
						<!-- Populated by JS -->
					</tbody>
				</table>
			</div>
		</div>

		<!-- ====================================================
		     BOTTOM ACTION BUTTONS
		     ==================================================== -->
		<div class="reconsile-bottom-actions">
			<button type="button" class="reconsile-btn-cancel" id="btnCancelReconciliation">
				ยกเลิกกระทบยอด
			</button>
			<button type="button" class="reconsile-btn-reconcile" id="btnReconciliation">
				กระทบยอด
			</button>
		</div>

	</div>
</div>

<!-- ============================================================
     MODALS
     ============================================================ -->

<!-- Edit Modal -->
<div class="modal fade reconsile-modal" id="editReconciliationModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
	<div class="modal-dialog modal-dialog-centered reconsile-modal-edit">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">แก้ไขข้อมูล</h5>
			</div>
			<div class="modal-body reconsile-edit-body">
				<input type="hidden" id="editReconciliationTranId" />
				<div class="reconsile-kv-row">
					<span class="reconsile-kv-label">Header Card</span>
					<span class="reconsile-kv-value" id="editDisplayHeaderCard">-</span>
				</div>
				<div class="reconsile-kv-row">
					<span class="reconsile-kv-label">เวลานับคัด</span>
					<span class="reconsile-kv-value" id="editDisplayTime">-</span>
				</div>
				<div class="reconsile-kv-row">
					<span class="reconsile-kv-label">ชนิดราคา</span>
					<span class="reconsile-kv-value" id="editDisplayDenom">-</span>
				</div>
				<div class="reconsile-kv-row">
					<span class="reconsile-kv-label">แบบ</span>
					<span class="reconsile-kv-value" id="editDisplayType">-</span>
				</div>
				<div class="reconsile-kv-row">
					<span class="reconsile-kv-label">ประเภท</span>
					<span class="reconsile-kv-value" id="editDisplayCategory">-</span>
				</div>
				<div class="reconsile-kv-row">
					<span class="reconsile-kv-label">จำนวน (ฉบับ)</span>
					<span class="reconsile-kv-value"><input type="number" class="form-control reconsile-edit-qty" id="editQuantity" min="1" max="1000" step="1" value="" /></span>
				</div>
				<div class="reconsile-kv-row">
					<span class="reconsile-kv-label">มูลค่า (บาท)</span>
					<span class="reconsile-kv-value" id="editDisplayValue">-</span>
				</div>
				<div class="reconsile-inline-error" id="editFormError"></div>
			</div>
			<div class="modal-footer justify-content-between">
				<button type="button" class="reconsile-btn-popup btn-cancel-popup" data-bs-dismiss="modal">ยกเลิก</button>
				<button type="button" class="reconsile-btn-popup btn-confirm-popup" id="btnConfirmEdit">บันทึก</button>
			</div>
		</div>
	</div>
</div>
<!-- Edit Confirm Modal -->
<div class="modal fade reconsile-modal reconsile-modal-confirm" id="editConfirmReconciliationModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content text-center">
			<div class="modal-body">
				<i class="bi bi-exclamation-diamond-fill confirm-icon"></i>
				<h4 class="confirm-title">แก้ไขข้อมูล</h4>
				<p class="confirm-message">คุณแน่ใจหรือไม่ที่ต้องการแก้ไขข้อมูลนี้</p>
			</div>
			<div class="modal-footer justify-content-center">
				<button type="button" class="reconsile-btn-popup btn-cancel-popup" data-bs-dismiss="modal">ยกเลิก</button>
				<button type="button" class="reconsile-btn-popup btn-danger-popup" id="btnConfirmEditAction">ยืนยัน</button>
			</div>
		</div>
	</div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade reconsile-modal reconsile-modal-confirm" id="deleteReconciliationModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content text-center">
			<div class="modal-body">
				<input type="hidden" id="deleteReconciliationTranId" />
				<i class="bi bi-exclamation-diamond-fill confirm-icon"></i>
				<h4 class="confirm-title">ลบข้อมูล 1 รายการ</h4>
				<p class="confirm-message">คุณแน่ใจหรือไม่ที่ต้องการลบข้อมูลนี้</p>
			</div>
			<div class="modal-footer justify-content-center">
				<button type="button" class="reconsile-btn-popup btn-cancel-popup" data-bs-dismiss="modal">ยกเลิก</button>
				<button type="button" class="reconsile-btn-popup btn-danger-popup" id="btnConfirmDelete">ยืนยัน</button>
			</div>
		</div>
	</div>
</div>


<!-- Success Modal -->
<div class="modal fade reconsile-modal reconsile-modal-success" id="reconsileSuccessModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content text-center">
			<div class="modal-body">
				<i class="bi bi-check-circle-fill success-icon"></i>
				<h4 class="success-title">สำเร็จ</h4>
				<p class="success-message" id="successMessage">ดำเนินการเรียบร้อย</p>
			</div>
			<div class="modal-footer justify-content-center" style="gap: 24px;">
				<button type="button" class="reconsile-btn-popup btn-cancel-popup" id="btnSuccessCancel" data-bs-dismiss="modal" onclick="onSuccessCancelClick()" style="display:none;">ยกเลิก</button>
				<button type="button" class="reconsile-btn-popup btn-confirm-popup" data-bs-dismiss="modal">ตกลง</button>
			</div>
		</div>
	</div>
</div>

<!-- Error Modal -->
<div class="modal fade reconsile-modal" id="reconsileErrorModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content text-center">
			<div class="modal-body py-5">
				<i class="bi bi-x-circle-fill confirm-icon" style="color: #DC3545;"></i>
				<h4 class="confirm-title">เกิดข้อผิดพลาด</h4>
				<p id="reconsileErrorMessage">กรุณาลองใหม่อีกครั้ง</p>
			</div>
			<div class="modal-footer justify-content-center">
				<button type="button" class="reconsile-btn-popup btn-cancel-popup" data-bs-dismiss="modal">ปิด</button>
			</div>
		</div>
	</div>
</div>

<!-- Cancel Reconcile Confirm Modal -->
<div class="modal fade modal-popup" id="cancelReconciliationModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered" style="max-width: 560px;">
		<div class="modal-content text-center" style="min-height: 300px; display: flex; flex-direction: column;">
			<div style="padding: 32px 16px 16px; flex-shrink: 0;">
				<i class="bi bi-exclamation-diamond-fill" style="font-size: 48px; color: #FD7E14;"></i>
				<h4 style="font-family: 'bss-pridi', sans-serif !important; font-size: 24px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.6px; line-height: 1.2; margin-top: 16px;">ยกเลิกกระทบยอด</h4>
			</div>
			<div style="padding: 24px 32px; flex: 1; display: flex; align-items: center; justify-content: center;">
				<p style="font-family: 'bss-pridi', sans-serif !important; font-size: 20px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.5px; line-height: 1.2; margin: 0;">ต้องการยกเลิกกระทบยอดใช่หรือไม่?</p>
			</div>
			<div class="modal-action-bar" style="justify-content: center; gap: 16px;">
				<button type="button" class="btn-popup btn-popup-cancel" data-bs-dismiss="modal">ไม่</button>
				<button type="button" class="btn-popup btn-popup-primary" id="btnConfirmCancelReconciliation">ใช่</button>
			</div>
		</div>
	</div>
</div>

<!-- ═══ Reconcile Warning Modal (Step 07) ═══ -->
<!-- ═══ Swapped Bundle Warning Modal (UC05) ═══ -->
<div class="modal fade modal-popup" id="swappedWarningModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered" style="max-width: 560px;">
		<div class="modal-content text-center" style="min-height: 360px; display: flex; flex-direction: column;">
			<div style="padding: 32px 16px 16px; flex-shrink: 0;">
				<i class="bi bi-exclamation-diamond-fill" style="font-size: 48px; color: #FD7E14;"></i>
				<h4 style="font-family: 'bss-pridi', sans-serif !important; font-size: 24px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.6px; line-height: 1.2; margin-top: 16px;">การแจ้งเตือน</h4>
			</div>
			<div style="padding: 24px 32px; flex: 1; display: flex; align-items: center; justify-content: center;">
				<p style="font-family: 'bss-pridi', sans-serif !important; font-size: 20px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.5px; line-height: 1.2; margin: 0;" id="swappedWarningMessage"></p>
			</div>
			<div class="modal-action-bar" style="justify-content: center;">
				<button type="button" class="btn-popup btn-popup-primary" data-bs-dismiss="modal">ตกลง</button>
			</div>
		</div>
	</div>
</div>

<!-- ═══ Multi-Bundle Alert Modal (UC01) ═══ -->
<div class="modal fade modal-popup" id="multiBundleAlertModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered" style="max-width: 560px;">
		<div class="modal-content text-center" style="min-height: 360px; display: flex; flex-direction: column;">
			<div style="padding: 32px 16px 16px; flex-shrink: 0;">
				<i class="bi bi-exclamation-diamond-fill" style="font-size: 48px; color: #FD7E14;"></i>
				<h4 style="font-family: 'bss-pridi', sans-serif !important; font-size: 24px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.6px; line-height: 1.2; margin-top: 16px;">การแจ้งเตือน</h4>
			</div>
			<div style="padding: 24px 32px; flex: 1; display: flex; align-items: center; justify-content: center;">
				<p style="font-family: 'bss-pridi', sans-serif !important; font-size: 20px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.5px; line-height: 1.2; margin: 0;" id="multiBundleAlertMessage"></p>
			</div>
			<div class="modal-action-bar" style="justify-content: center;">
				<button type="button" class="btn-popup btn-popup-primary" data-bs-dismiss="modal">ตกลง</button>
			</div>
		</div>
	</div>
</div>

<!-- ═══ HC Locked Modal (UC02) ═══ -->
<div class="modal fade modal-popup" id="hcLockedModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered" style="max-width: 560px;">
		<div class="modal-content text-center" style="min-height: 360px; display: flex; flex-direction: column; border: 1px solid #EEEEEE; border-radius: 12px;">
			<div style="padding: 32px 16px 16px; flex-shrink: 0;">
				<i class="bi bi-lock-fill" style="font-size: 48px; color: #DC3545;"></i>
				<h4 style="font-family: 'bss-pridi', sans-serif !important; font-size: 24px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.6px; line-height: 1.2; margin-top: 16px;" id="hcLockedTitle">Header Card ล็อก</h4>
			</div>
			<div style="padding: 24px 32px; flex: 1; display: flex; align-items: center; justify-content: center;">
				<p style="font-family: 'bss-pridi', sans-serif !important; font-size: 16px !important; font-weight: 400 !important; color: #000 !important; letter-spacing: 0.4px; line-height: 1.5; margin: 0;" id="hcLockedMessage"></p>
			</div>
			<div class="modal-action-bar" style="justify-content: center; border-top: 1px solid #CBD5E1;">
				<button type="button" class="btn-popup btn-popup-primary" data-bs-dismiss="modal">ตกลง</button>
			</div>
		</div>
	</div>
</div>

<div class="modal fade modal-popup" id="reconsileWarningModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered" style="max-width: 560px;">
		<div class="modal-content text-center" style="min-height: 360px; display: flex; flex-direction: column;">
			<div style="padding: 32px 16px 16px; flex-shrink: 0;">
				<i class="bi bi-exclamation-diamond-fill" style="font-size: 48px; color: #FD7E14;"></i>
				<h4 style="font-family: 'bss-pridi', sans-serif !important; font-size: 24px !important; font-weight: 500 !important; color: #000 !important; letter-spacing: 0.6px; line-height: 1.2; margin-top: 16px;">การแจ้งเตือน</h4>
