@model BSS_WEB.Views.Revoke.RevokeAutoSelling.IndexModel
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	ViewData["Title"] = "RevokeAutoSelling";
}

<link rel="stylesheet" href="@Url.Content("~/css/master/all.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-modal-popup.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/revoke/revokeTransaction.css")" asp-append-version="true" />
@if (Model.CssVariantClass == "revoke-unsort-cc") {
	<link rel="stylesheet" href="@Url.Content("~/css/revoke/revoke-unsort-cc.css")" asp-append-version="true" />
} else if (Model.CssVariantClass == "revoke-ca-member") {
	<link rel="stylesheet" href="@Url.Content("~/css/revoke/revoke-ca-member.css")" asp-append-version="true" />
} else if (Model.CssVariantClass == "revoke-ca-non-member") {
	<link rel="stylesheet" href="@Url.Content("~/css/revoke/revoke-ca-non-member.css")" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<input type="hidden" id="currentUserId" value="@User.FindFirst("UserID")?.Value" />
<input type="hidden" id="currentDepartmentId" value="@User.FindFirst("DepartmentID")?.Value" />
<input type="hidden" id="currentUserFullName"
	   value="@( (User.FindFirst("FirstName")?.Value ?? "") + " " + (User.FindFirst("Lastname")?.Value ?? "") )" />
<input type="hidden" id="cssVariantClass" value="@Model.CssVariantClass" />
<input type="hidden" id="bnTypeCode" value="@Model.BnTypeCode" />

<div class="main-wrapper">
	<div class="sub-wrapper">
	<div class="layout">

		<!-- ============================================================
		     TITLE BAR
		     ============================================================ -->
		<div class="title-bar">
			<div class="page-title">Revoke @Model.BnTypeName</div>

			<div class="info-panel">
				<div class="info-item">
					<span class="info-label">Date:</span>
					<span class="info-value" id="infoDate">-</span>
				</div>
				<div class="info-item">
					<span class="info-label">Supervisor:</span>
					<span class="info-value">@Model.Verifier</span>
				</div>
			</div>

			<button class="btn-filter" id="btnToggleFilter" onclick="toggleFilter()">
				<img src="data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cg clip-path='url(%23clip0_3753_19274)'%3E%3Cpath d='M7.99963 0C12.4179 0 15.9996 3.58172 15.9996 8C15.9996 12.4183 12.4179 16 7.99963 16C3.58136 16 -0.000363672 12.4183 -0.000366211 8C-0.000366211 3.58172 3.58136 2.58759e-06 7.99963 0ZM7.99963 1C4.13364 1 0.999634 4.13401 0.999634 8C0.999636 11.866 4.13364 15 7.99963 15C11.8656 15 14.9996 11.866 14.9996 8C14.9996 4.13401 11.8656 1 7.99963 1ZM8.49963 11C8.77578 11 8.99963 11.2239 8.99963 11.5C8.99963 11.7761 8.77577 12 8.49963 12H7.49963C7.2235 12 6.99964 11.7761 6.99963 11.5C6.99963 11.2239 7.22349 11 7.49963 11H8.49963ZM10.4996 8C10.7758 8 10.9996 8.22386 10.9996 8.5C10.9996 8.77614 10.7758 9 10.4996 9H5.49963C5.2235 9 4.99964 8.77614 4.99963 8.5C4.99963 8.22386 5.22349 8 5.49963 8H10.4996ZM12.4996 5C12.7758 5 12.9996 5.22386 12.9996 5.5C12.9996 5.77614 12.7758 6 12.4996 6H3.49963C3.2235 6 2.99964 5.77614 2.99963 5.5C2.99963 5.22386 3.22349 5 3.49963 5H12.4996Z' fill='white'/%3E%3C/g%3E%3Cdefs%3E%3CclipPath id='clip0_3753_19274'%3E%3Crect width='16' height='16' fill='white'/%3E%3C/clipPath%3E%3C/defs%3E%3C/svg%3E" width="16" height="16" class="btn-icon" />
				<span class="btn-text">Filter</span>
			</button>
		</div>

		<!-- ============================================================
		     FILTER BAR — toggle via Filter button
		     ============================================================ -->
		<div class="filter-bar" id="filterSection" style="display:none;">
			<div class="filter-bar-inner">
				<div class="filter-group" id="filterGroupBank">
					<label class="filter-label">ธนาคาร:</label>
					<select class="filter-select filter-select--bank" id="filterBank">
						<option value="">Please select</option>
					</select>
				</div>
				<div class="filter-group" id="filterGroupZone">
					<label class="filter-label">Zone:</label>
					<select class="filter-select filter-select--zone" id="filterZone">
						<option value="">Please select</option>
					</select>
				</div>
				<div class="filter-group" id="filterGroupCashpoint">
					<label class="filter-label">Cashpoint:</label>
					<select class="filter-select filter-select--cashpoint" id="filterCashpoint">
						<option value="">Please select</option>
					</select>
				</div>
				<div class="filter-group" id="filterGroupCashCenter" style="display:none;">
					<label class="filter-label">ศูนย์เงินสด:</label>
					<select class="filter-select filter-select--cash-center" id="filterCashCenter">
						<option value="">Please select</option>
					</select>
				</div>
				<div class="filter-group" id="filterGroupDenomination">
					<label class="filter-label">ชนิดราคา:</label>
					<select class="filter-select filter-select--denomination" id="filterDenomination">
						<option value="">Please select</option>
					</select>
				</div>
			</div>
		</div>

		<!-- ============================================================
		     REVOKE CONTENT — Single Column Layout
		     ============================================================ -->
		<div class="revoke-content">

			<!-- ตารางบน: รายการ Header Card -->
			<div class="hc-table-section">
				<div class="table-section-header">
					<span class="table-section-title">รายการ Header Card</span>
					<div class="table-section-count">
						<span class="table-section-count-label">จำนวน:</span>
						<span class="table-section-count-value" id="hcTotalCount">0</span>
						<span class="table-section-count-label">รายการ</span>
					</div>
				</div>
				<div class="table-scroll-area">
					<table class="revoke-table" id="hcTable">
						<thead><tr id="hcTableHead"></tr></thead>
						<tbody id="hcTableBody">
							<tr><td colspan="8" class="text-center text-muted">กำลังโหลด...</td></tr>
						</tbody>
					</table>
				</div>
			</div>

			<!-- ตารางล่าง: แสดงผลการนับคัดตาม Header Card ที่เลือกไว้ -->
			<div class="detail-table-section" id="detailSection" style="display:none;">
				<div class="table-section-header">
					<span class="table-section-title">แสดงผลการนับคัดตามรายการ Header Card ที่เลือกไว้</span>
					<div class="table-section-count">
						<span class="table-section-count-label">จำนวนธนบัตร:</span>
						<span class="table-section-count-value" id="detailTotalQty">0</span>
						<span class="table-section-count-label">ฉบับ</span>
					</div>
				</div>
				<div class="table-scroll-area">
					<table class="revoke-table" id="detailTable">
						<thead>
							<tr>
								<th class="th-sort" data-sort="denominationPrice" onclick="sortDetailTable('denominationPrice')">ชนิดราคา <i class="bi bi-chevron-expand sort-icon"></i></th>
								<th class="th-sort" data-sort="bnType" onclick="sortDetailTable('bnType')">ประเภท <i class="bi bi-chevron-expand sort-icon"></i></th>
								<th class="th-sort" data-sort="denomSeries" onclick="sortDetailTable('denomSeries')">แบบ <i class="bi bi-chevron-expand sort-icon"></i></th>
								<th class="th-sort" data-sort="qty" onclick="sortDetailTable('qty')">จำนวนฉบับ <i class="bi bi-chevron-expand sort-icon"></i></th>
							</tr>
						</thead>
						<tbody id="detailTableBody">
							<tr><td colspan="4" class="text-center text-muted">เลือก Header Card ด้านบนเพื่อแสดงรายละเอียด</td></tr>
						</tbody>
					</table>
				</div>
			</div>

		</div>

		<!-- ============================================================
		     FOOTER — Revoke button
		     ============================================================ -->
		<div class="footer-bar">
			<div class="footer-spacer"></div>
			<button class="btn-revoke" id="btnRevoke" onclick="openRevokeConfirmModal()">
				Revoke
			</button>
		</div>

	</div>
	</div>
</div>

<!-- ══════════════════════════════════════════════════════
     MODALS
     ══════════════════════════════════════════════════════ -->

<!-- Modal: Reconfirm Revoke — 2-step with OTP -->
<div class="modal fade modal-popup modal-revoke-confirm" id="revokeConfirmModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered modal-xl">
		<div class="modal-content">

			<!-- Step A: เลือก Manager + ตาราง -->
			<div class="modal-step active" id="revokeStepA">
				<div class="modal-top-bar">
					<h5 class="modal-title">Reconfirm Revoke</h5>
				</div>
				<div class="modal-body-area">
					<div class="modal-table-section">
						<div class="table-section-header">
							<span class="table-section-title">รายการ Header Card</span>
						</div>
						<div class="modal-table-scroll">
							<table class="revoke-table" id="revokeConfirmTable">
								<thead><tr id="revokeConfirmTableHead"></tr></thead>
								<tbody id="revokeConfirmTableBody"></tbody>
							</table>
						</div>
					</div>
					<div class="modal-confirm-section">
						<h5 class="modal-confirm-title">ยืนยัน Revoke</h5>
						<div class="modal-manager-row">
							<label class="modal-manager-label">เลือก Manager</label>
							<select class="modal-manager-select" id="selectManager">
								<option value="">กรุณาเลือก</option>
							</select>
							<div class="popup-inline-error" id="revokeManagerError">กรุณาเลือก Manager</div>
						</div>
					</div>
				</div>
				<div class="modal-action-bar">
					<button class="btn-popup btn-popup-cancel" data-bs-dismiss="modal">ยกเลิก</button>
					<button class="btn-popup btn-popup-confirm" onclick="confirmRevokeStepA()">ส่งคำขออนุมัติ</button>
				</div>
			</div>

			<!-- Step B: OTP Input -->
			<div class="modal-step" id="revokeStepB">
				<div class="modal-top-bar">
					<h5 class="modal-title">Reconfirm Revoke</h5>
				</div>
				<div class="modal-body-area">
					<div class="modal-confirm-section">
						<h5 class="modal-confirm-title">ยืนยัน Revoke</h5>
						<div class="revoke-otp-info-rows">
							<div class="revoke-otp-info-row">
								<span>จำนวนรายการ</span>
								<span id="revokeOtpCount">0</span>
							</div>
							<div class="revoke-otp-info-row">
								<span>Manager</span>
								<span id="revokeOtpManager">-</span>
							</div>
						</div>
						<div class="revoke-otp-group">
							<label class="modal-manager-label">Manager กรอกรหัส OTP</label>
							<input type="text" class="revoke-otp-input" id="revokeOtpInput" maxlength="6" placeholder="กรอกรหัส OTP 6 หลัก" autocomplete="off" disabled />
							<div class="popup-inline-error" id="revokeOtpError">กรุณากรอกรหัส OTP 6 หลัก</div>
							<div class="revoke-otp-sent-msg" id="revokeOtpSentMsg" style="display:none;">
								<span class="otp-sent-text">ส่งรหัส OTP แล้ว</span>
							</div>
							<div class="revoke-otp-resend-row" id="revokeOtpResendRow" style="display:none;">
								<button class="btn-resend-otp" id="btnRevokeResendOtp" onclick="sendRevokeOtp()" disabled>
									<svg class="resend-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M7.5898 0.3412C7.7526 0.2056 7.9999 0.3208 8 0.5326V1.9994C11.3136 1.9996 14 4.6858 14 7.9994C13.9998 11.3129 11.3135 13.9993 8 13.9994C4.6864 13.9994 2.0002 11.313 2 7.9994C2 7.1069 2.1954 6.2581 2.5459 5.4955C2.6613 5.2449 2.9582 5.1351 3.209 5.2504C3.4596 5.3659 3.5694 5.6627 3.4541 5.9135C3.1626 6.5477 3 7.254 3 7.9994C3.0002 10.7607 5.2387 12.9994 8 12.9994C10.7612 12.9993 12.9998 10.7606 13 7.9994C13 5.2381 10.7613 2.9996 8 2.9994V4.4653C8 4.6771 7.7527 4.793 7.5898 4.6576L5.2305 2.6908C5.1105 2.5909 5.1105 2.407 5.2305 2.3071L7.5898 0.3412Z" fill="currentColor"/>
									</svg>
									ส่งรหัส OTP อีกครั้ง
								</button>
								<span class="otp-timer" id="revokeOtpTimer"></span>
							</div>
						</div>
					</div>
				</div>
				<div class="modal-action-bar">
					<button class="btn-popup btn-popup-cancel" data-bs-dismiss="modal">ยกเลิก</button>
					<button class="btn-popup btn-popup-confirm" id="btnRevokeConfirmOtp" onclick="confirmRevokeOtp()">ยืนยัน OTP</button>
				</div>
			</div>

		</div>
	</div>
</div>

<!-- Modal: Success -->
<div class="modal fade modal-popup" id="revokeSuccessModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-body text-center py-5">
				<div class="mb-4">
					<div class="modal-success-title">
						<i class="bi bi-check-circle-fill"></i>
					</div>
				</div>
				<h3 class="fw-bold mb-3">สำเร็จ!</h3>
				<h6 class="mb-4" id="successMessage">ดำเนินการสำเร็จ</h6>
			</div>
			<div class="modal-footer justify-content-center">
				<button class="btn btn-green px-5" onclick="closeSuccessModal()">
					<i class="bi bi-check-lg"></i> ตกลง
				</button>
			</div>
		</div>
	</div>
</div>

<!-- Modal: Error -->
<div class="modal fade modal-popup" id="revokeErrorModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-body text-center py-5">
				<div class="mb-4">
					<div class="modal-warning-title">
						<i class="bi bi-exclamation-diamond-fill"></i>
					</div>
				</div>
				<h3 class="fw-bold mb-3">การแจ้งเตือน</h3>
				<h6 class="mb-4" id="revokeErrorMessage">ข้อความผิดพลาด</h6>
			</div>
			<div class="modal-footer justify-content-center gap-2">
				<button type="button" class="btn btn-blue px-4" data-bs-dismiss="modal">ตกลง</button>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="@Url.Content("~/js/shared/bss-modal.js")" asp-append-version="true"></script>
	<script src="@Url.Content("~/js/revoke/revokeTransaction.js")" asp-append-version="true"></script>
}
