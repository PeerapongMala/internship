@model BSS_WEB.Views.PrePreparationUnsort.RegisterUnsortDeliver.CreateUnsortDeliverModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "สร้างใบนำส่ง UNSORT CC";
}


<link rel="stylesheet" href="@Url.Content("~/css/master/all.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/preparation/unsortCC.css")" asp-append-version="true" />

<!--<link rel="stylesheet" href="@Url.Content("~/css/registerUnsortcc/CreateUnsortDeliver.css")" />-->

<div class="main-wrapper">
    <div class="sub-wrapper">
        <div class="layout">

            <div class="main-title mb-2">
                <div class="title-left">
                    <div class="title-section">
                        <h1>สร้างใบนำส่ง UNSORT CC</h1>
                    </div>
                </div>
                <div class="title-right">
                </div>
            </div>

            <div class="white-card mb-2">
                <div class="row g-3 align-items-center row-cols-1 row-cols-lg-3">
                    <div class="col">
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <label class="form-label fw-semibold mb-0 text-nowrap">รหัสใบนำส่ง: </label>
                            </div>
                            <div class="col">
                                <input type="text" id="txtDeliveryCode" class="form-control" disabled>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <label class="form-label fw-semibold mb-0 text-nowrap">บาร์โค้ดภาชนะ: </label>
                            </div>
                            <div class="col">
                                <select id="ddlContainer" class="form-select" disabled>
                                    <option value="">-- ทั้งหมด --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="row g-2 align-items-center flex-nowrap">
                            <div class="col-auto">
                                <label class="form-label fw-semibold mb-0 text-nowrap">วันที่ลงทะเบียน: </label>
                            </div>
                            <div class="col">
                                <div class="date-range-wrapper">
                                    <div class="date-range-input-group d-flex align-items-center border rounded p-1 bg-white">
                                        <input type="text" id="filterDateStart"
                                               class="form-control form-control-sm border-0 bg-transparent flex-fill text-center min-w-0"
                                               placeholder="dd/mm/yyyy" readonly>
                                        <span class="px-1 small text-muted">ถึง</span>
                                        <input type="text" id="filterDateEnd"
                                               class="form-control form-control-sm border-0 bg-transparent flex-fill text-center min-w-0"
                                               placeholder="dd/mm/yyyy" readonly>
                                        <button type="button" class="btn btn-link btn-sm p-0 ms-1" onclick="resetDateToNow()">
                                            <i class="bi bi-calendar-check"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="main-content-pt3 mb-2">
                <div class="row">
                    <div class="full-panel">

                        <div class="white-card">
                            <div class="table-controls">
                                <div class="wc-header-left">
                                    <span class="card-title">รายการภาชนะ</span>
                                </div>
                                <div class="wc-header-right">
                                </div>
                            </div>
                            <div id="containerScroll" class="main-table-preparation-scroll">
                                <table class="data-table preparationREGISTER_UNSORT_CC_DL_CREATE">
                                    <thead>
                                        <tr>
                                            <th>
                                                <input type="checkbox" id="checkAll" onclick="toggleSelectAll(this)">
                                            </th>
                                            <th>บาร์โค้ดภาชนะ</th>
                                            <th>วันที่ลงทะเบียน</th>
                                            <th>สถานะ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="createTableBody">
                                    </tbody>
                                </table>
                            </div>
                         </div>

                    </div>
                </div>
            </div>

            <div class="main-content-pt3">
                <div class="row">
                    <div class="full-panel">

                        <div id="detailSection" class="white-card">

                            <div class="table-controls">
                                <div class="wc-header-left">
                                    <span class="card-title">รายการลงทะเบียนธนบัตรตามบาร์โค้ดภาชนะที่เลือก</span>
                                </div>
                                <div class="wc-header-right">
                                    <span class="card-title">จำนวนมัด: <strong id="totalBundleSum" class="status-count">0</strong> มัด</span>
                                </div>
                            </div>

                            <div id="tableBodyScroll" class="main-table-preparation-scroll">
                                <table class="data-table preparationREGISTER_UNSORT_CC_DL_CREATE_SUB">
                                    <thead>
                                        <tr>
                                            <th>ธนาคาร</th>
                                            <th>ชนิดราคา</th>
                                            <th>จำนวน (มัด)</th>
                                            <th>วันที่ลงทะเบียน</th>
                                        </tr>
                                    </thead>
                                    <tbody id="detailTableBody">
                                    </tbody>
                                </table>
                            </div>

                        </div>

                        <div class="row">
                            <div class="btn-wrapper d-flex">
                                <button type="button" class="btn btn-gray px-4" onclick="goBack()">ยกเลิก</button>

                                <button type="button" id="btnConfirm" class="btn btn-green px-5 ms-auto" onclick="confirmCreateDelivery()" disabled>ยืนยันสร้างใบนำส่ง</button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="DeleteModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3">ยืนยันการสร้างใบนำส่ง</h3>
                <h6 class="mb-4">คุณแน่ใจหรือไม่ที่ต้องการสร้างใบนำส่งนี้?</h6>
            </div>
            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-green px-4" onclick="confirmCreateDeliverySubmit()">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="commonSuccessModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-success-title">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3">สำเร็จ!</h3>
                <h6 id="successModalMessage" class="text-muted mb-4">ดำเนินการเรียบร้อยแล้ว</h6>
            </div>
            <div class="modal-footer justify-content-center">
                <button class="btn btn-green px-5" data-bs-dismiss="modal" onclick="onSuccessDone()">
                    <i class="bi bi-check-lg"></i> ตกลง
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="@Url.Content("~/js/registerUnsortCC/CreateUnsortDeliver.js")" asp-append-version="true"></script>
}