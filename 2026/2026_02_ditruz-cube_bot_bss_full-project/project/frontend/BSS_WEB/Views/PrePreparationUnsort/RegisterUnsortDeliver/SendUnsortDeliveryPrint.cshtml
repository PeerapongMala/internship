@{
    Layout = null;
}

@model BSS_WEB.Models.Report.RegisterUnsort.SendUnsortDeliveryReportModel;
<link rel="stylesheet" href="@Url.Content("~/css/registerUnsortcc/SendUnsortDeliveryPrint.css")" asp-append-version="true" />

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <title>พิมพ์ใบนำส่ง</title>

    <link href="~/css/bss-loading.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <!-- ===== Header Toolbar ===== -->
    <div class="top-toolbar">
        <div class="toolbar-left">
            <h3>ใบนำส่ง</h3>
        </div>

        <div class="export-options">
            <label>
                <input type="radio" name="exportType" id="rdPdf" value="pdf" checked>
                PDF
            </label>

            <label style="margin-left: 15px;">
                <input type="radio" name="exportType" id="rdExcel" value="excel">
                Excel
            </label>

            <button type="button" class="btn-export" onclick="exportData()">
                Export
            </button>
        </div>
    </div>

    <hr />

    <div id="report-body" style="display:none;">
        <h1>@Model.ReportTitle</h1>

        <div class="header-info">
            <div class="header-row">
                <span class="label">รหัสเอกสาร : @Model.ReportHeader.SendUnsortCode</span>
                <span></span>
            </div>
            <div class="header-row">
                <span>วันที่ : @Model.ReportHeader.PrintDate</span>
            </div>
        </div>

        <div class="header-info">
            <div class="header-row">
                <span class="label">Supervisor : @Model.ReportHeader.SupervisorName</span>
                <span></span>
            </div>
            <div class="header-row">
                <span>Ref Code : @Model.ReportHeader.RefCode</span>
            </div>
        </div>

        <div class="header-row">
            <span class="label">ศูนย์นับคัด : @Model.ReportHeader.DepartmentName</span>
            <span></span>
        </div>

        <table>
            <thead>
                <tr>
                    <th>ลำดับ</th>
                    <th>รหัสภาชนะ</th>
                    <th>สถาบันการเงิน</th>
                    <th>ชนิดราคา</th>
                    <th>จำนวน (มัด)</th>
                </tr>
            </thead>
            <tbody>

                @{
                    int detail_index = 1;
                }

                @foreach (var reportDetail in Model.ReportDetail)
                {
                    <tr>
                        <td>@detail_index</td>
                        <td>@reportDetail.ContainerCode</td>
                        <td>@reportDetail.InstitutionName</td>
                        <td>@reportDetail.DenominationPrice</td>
                        <td>@reportDetail.TotalBundle</td>
                    </tr>

                    detail_index++;
                }

            </tbody>
        </table>
    </div>

    <div id="pdf-viewer-container" style="width: 100%; height: 92%;">
        <iframe id="pdf-iframe" style="width: 100%; height: 100%; border: none; display: none;" title=""></iframe>
    </div>


    
    <div class="print-toolbar">
        <button type="button" class="btn-back btn btn-secondary" onclick="goBack()">ย้อนกลับ</button>
        <button type="button" class="btn-print" onclick="printPage()">พิมพ์</button>
    </div>

    <div id="pageloading">
        <div class="loading-overlay">
            <div class="loading-box">
                <div class="custom-spinner"></div>
                <span class="loading-text">Loading...</span>
            </div>
        </div>
    </div>

    <input type="hidden" id="hdn-ids"
           value="@(ViewBag.Ids != null ? string.Join(",", ViewBag.Ids) : "")" />

    <script src="@Url.Content("~/lib/jquery/dist/jquery.min.js")"></script>

    <script src="@Url.Content("~/js/registerUnsortCC/SendUnsortDeliveryPrint.js")" asp-append-version="true"></script>

    <script src="@Url.Content("~/js/helpers/bss-report-export.js")"></script>
    <script src="@Url.Content("~/lib/html2canvas/html2canvas.js")"></script>
    <script src="@Url.Content("~/lib/jspdf/jspdf.umd.min.js")"></script>
</body>
</html>