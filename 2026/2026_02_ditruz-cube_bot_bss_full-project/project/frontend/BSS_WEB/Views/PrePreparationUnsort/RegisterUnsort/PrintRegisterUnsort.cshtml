@{
    Layout = null;
}

@model BSS_WEB.Models.Report.RegisterUnsort.RegisterUnsortReportModel;
<link rel="stylesheet" href="@Url.Content("~/css/registerUnsortcc/PrintRegisterUnsortcc.css")" asp-append-version="true" />

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <title>พิมพ์เอกสารลงทะเบียน</title>

    <link href="~/css/bss-loading.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <!-- ===== Header Toolbar ===== -->
    <div class="top-toolbar">
        <div class="toolbar-left">
            <h3>Print Unsort CC Data</h3>
        </div> 

        <div class="export-options">
            <label>
                <input type="radio" name="exportType" id="rdPdf" value="pdf" checked>
                PDF
            </label>

            <label style="margin-left: 15px;">
                <input type="radio" name="exportType" id="rdExcel" value="excel">
                Excel
            </label>

            <button type="button" class="btn-export" onclick="exportData()">
                Export
            </button>
        </div>
    </div>

    <hr />

    <div id="report-body" style="display:none;">
        <h1>@Model.ReportTitle</h1>

        <div class="header-info">
            <div class="header-row">
                <span class="label">บาร์โค้ดภาชนะ :</span>
                <span>@Model.ReportHeader.BarcodeContainer</span>
            </div>
            <div class="header-row">
                <span>วันที่ลงทะเบียน : @Model.ReportHeader.RegisterDate</span>
            </div>
        </div>

        <div class="header-row">
            <span class="label">Operator :</span>
            <span>@Model.ReportHeader.OperatorName</span>
        </div>

        <div class="header-row">
            <span class="label">ศูนย์นับคัด :</span>
            <span>@Model.ReportHeader.DepartmentName</span>
        </div>

        <table>
            <thead>
                <tr>
                    <th>ลำดับ</th>
                    <th>ธนาคาร</th>
                    <th>ชนิดราคา</th>
                    <th>จำนวน (มัด)</th>
                    <th>วันที่ลงทะเบียน</th>
                    <th>ผู้บันทึก/เครื่อง</th>
                </tr>
            </thead>
            <tbody>

                @{
                    int detail_index = 1;
                }

                @foreach (var reportDetail in Model.ReportDetail)
                {
                    <tr>
                        <td>@detail_index</td>
                        <td>@reportDetail.InstitutionName</td>
                        <td>@reportDetail.DenominationPrice</td>
                        <td>@reportDetail.TotalBundle</td>
                        <td>@reportDetail.CreatedDate</td>
                        <td>@reportDetail.CreatedName</td>
                    </tr>

                    detail_index++;
                }

            </tbody>
        </table>

        <div class="footer-section">
            <table class="footer-table">
                <tr>
                    <td colspan="3" class="footer-title-cell">สรุปข้อมูลภาชนะ</td>
                </tr>
                <tr>
                    <td>บาร์โค้ดภาชนะ</td>
                    <td>จำนวนมัดรวม</td>
                    <td>จำนวนสถาบันการเงิน</td>
                </tr>
                <tr>
                    <td>@Model.ReportSummary.BarcodeContainer</td>
                    <td>@Model.ReportSummary.TotalAllBundle</td>
                    <td>@Model.ReportSummary.TotalAllInstitution</td>
                </tr>
            </table>
        </div>

    </div>

    <div id="pdf-viewer-container" style="width: 100%; height: 92%;">
        <iframe id="pdf-iframe" style="width: 100%; height: 100%; border: none; display: none;" title="pdfshowframe"></iframe>
    </div>
    
    <div class="print-toolbar">
        <button type="button" class="btn-back btn btn-secondary" onclick="goBack()">ย้อนกลับ</button>
        <button type="button" class="btn-print" onclick="printPage()">พิมพ์</button>
    </div>

    <div id="pageloading">
        <div class="loading-overlay">
            <div class="loading-box">
                <div class="custom-spinner"></div>
                <span class="loading-text">Loading...</span>
            </div>
        </div>
    </div>

    <input type="hidden" id="hdn-ids"
           value="@(ViewBag.Ids != null ? string.Join(",", ViewBag.Ids) : "")" />

    <script src="@Url.Content("~/lib/jquery/dist/jquery.min.js")"></script>

    <script src="@Url.Content("~/js/registerUnsortCC/PrintRegisterUnsort.js")" asp-append-version="true"></script>

    <script src="@Url.Content("~/js/helpers/bss-report-export.js")"></script>
    <script src="@Url.Content("~/lib/html2canvas/html2canvas.js")"></script>
    <script src="@Url.Content("~/lib/jspdf/jspdf.umd.min.js")"></script>
</body>
</html>