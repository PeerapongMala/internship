				<div style="max-width:540px; width:100%; padding:8px; display:flex; flex-direction:column; gap:16px; align-items:center;">
					<!-- Dropdown (Select2 style like Login) -->
					<select class="form-control form-select" id="dropdownDisplayTwo" style="width:100%;" data-placeholder="-- กรุณาเลือก --">
						<option></option>
					</select>
					<!-- Preview Card (Banknote style) -->
					<div id="secondScreenPreview" style="display:block;">
						<div id="previewOuterFrame" style="width:348px; border-radius:20px; border:10px solid #c8d0d8; background:#fff; padding:3px; transition:all 0.3s;">
							<div id="previewCard" style="border-radius:10px; border:6px solid #9f7d57; padding:16px; text-align:center; transition:all 0.3s; position:relative; overflow:hidden; background-color:#fbf8f4; background-image:linear-gradient(rgba(255,255,255,0.8), rgba(255,255,255,0.8)), var(--pattern-bg); background-size:cover; background-position:center;">
								<div id="previewCashpoint" style="font-family:'bss-pridi',sans-serif; font-size:28px; font-weight:700 !important; color:#4f3e2b; margin-bottom:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">-</div>
								<div style="display:flex; justify-content:center; align-items:baseline; margin-bottom:4px;">
									<span id="previewBank" style="font-family:'bss-pridi',sans-serif; font-size:32px; font-weight:700 !important; color:#4f3e2b; letter-spacing:3.6px; flex:1; text-align:center; ">-</span>
									<span id="previewDeno" style="font-family:'bss-pridi',sans-serif; font-size:32px; font-weight:700 !important; color:#4f3e2b; letter-spacing:3.6px; flex:1; text-align:center;">-</span>
								</div>
								<div id="previewHeaderCard" style="font-family:'bss-pridi',sans-serif; font-size:32px; font-weight:700 !important; color:#4f3e2b; letter-spacing:3.6px;">-</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<!-- Bottom Bar -->
			<div style="padding:16px; border-top:1px solid #cbd5e1; display:flex; justify-content:space-between;">
				<button class="btn" data-bs-dismiss="modal" style="min-width:160px; background:#6c757d; border:1px solid #6c757d; color:#fff; border-radius:6px; padding:7px 13px; font-family:'bss-pridi',sans-serif; font-size:16px; font-weight:400; letter-spacing:0.4px; line-height:1.5;">ยกเลิก</button>
				<button class="btn" onclick="confirmSecondScreen()" style="min-width:160px; background:#003366; border:1px solid #003366; color:#fff; border-radius:6px; padding:7px 13px; font-family:'bss-pridi',sans-serif; font-size:16px; font-weight:400; letter-spacing:0.4px; line-height:1.5;">ยืนยัน</button>
			</div>
		</div>
	</div>
</div>

