@model BSS_WEB.Views.AutoSelling.AutoSelling.IndexModel
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	ViewData["Title"] = "VerifyAutoSelling";
}

<link rel="stylesheet" href="@Url.Content("~/css/master/all.css")" asp-append-version="true" />
<!-- Shared CSS modules -->
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-sort.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-badges.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-modal-popup.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-scrollbar.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-table-section.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-review-table.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-edit-form-modal.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-otp-modal.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/shared/bss-print-report-modal.css")" asp-append-version="true" />
<!-- Page CSS -->
<link rel="stylesheet" href="@Url.Content("~/css/verify/verifyTransaction.css")" asp-append-version="true" />
@if (Model.CssVariantClass == "verify-unsort-cc") {
	<link rel="stylesheet" href="@Url.Content("~/css/verify/verify-unsort-cc.css")" asp-append-version="true" />
} else if (Model.CssVariantClass == "verify-ca-member") {
	<link rel="stylesheet" href="@Url.Content("~/css/verify/verify-ca-member.css")" asp-append-version="true" />
} else if (Model.CssVariantClass == "verify-ca-non-member") {
	<link rel="stylesheet" href="@Url.Content("~/css/verify/verify-ca-non-member.css")" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<input type="hidden" id="currentUserId" value="@User.FindFirst("UserID")?.Value" />
<input type="hidden" id="currentDepartmentId" value="@User.FindFirst("DepartmentID")?.Value" />
<input type="hidden" id="currentUserFullName"
	   value="@( (User.FindFirst("FirstName")?.Value ?? "") + " " + (User.FindFirst("Lastname")?.Value ?? "") )" />
<input type="hidden" id="cssVariantClass" value="@Model.CssVariantClass" />
<input type="hidden" id="bnTypeCode" value="@Model.BnTypeCode" />

<div class="main-wrapper">
	<div class="sub-wrapper">
	<div class="layout">

