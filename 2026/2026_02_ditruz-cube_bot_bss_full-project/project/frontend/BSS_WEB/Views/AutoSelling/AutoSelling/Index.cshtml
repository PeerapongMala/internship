	<script src="@Url.Content("~/js/shared/bss-sort.js")" asp-append-version="true"></script>
	<script src="@Url.Content("~/js/shared/bss-modal.js")" asp-append-version="true"></script>
	<script src="@Url.Content("~/js/shared/bss-dom.js")" asp-append-version="true"></script>
	<!-- Page JS -->
	<script src="@Url.Content("~/js/verify/verifyTransaction.js")" asp-append-version="true"></script>
}
