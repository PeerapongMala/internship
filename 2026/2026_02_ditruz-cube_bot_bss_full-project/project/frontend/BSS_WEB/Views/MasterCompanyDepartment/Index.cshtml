@{
    ViewData["Title"] = "Master Company Department";
}

<link rel="stylesheet" href="@Url.Content("~/css/master/admin.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/master/all.css")" asp-append-version="true" />


<!-- =======  Data-Table  = Start  ========================== -->
<div class="main-wrapper">
    <div class="sub-wrapper">
        <div class="layout">

            <div class="main-title">
                <div class="title-left">
                    <div class="title-section title-admin">
                        <h1>Master Company Department</h1>
                    </div>
                </div>
                <div class="title-right d-flex gap-2 mt-1">
                    <button type="button" class="btn btn-blue" id="btnItemCreate"
                            onclick="showCreatePopup();">
                        <i class="bi bi-plus-circle" fill="currentColor"></i> เพิ่มข้อมูล
                    </button>
                    <button type="button" class="btn btn-blue" id="btnToggleFilter">
                        <i class="bi bi-filter-circle" fill="currentColor"></i> Filter
                    </button>

                    @Html.AntiForgeryToken()
                </div>
            </div>

            <!-- =======  Filter - Display  = Start  ========================== -->
            <div class="container" id="filterDisplay">
                <div class="row">
                    <div class="col-4">
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <div for="ddlFilterCompany">ชื่อบริษัท:</div>
                            </div>
                            <div class="col">
                                <select class="form-control form-select"
                                        id="ddlFilterCompany"
                                        onchange="LoadCompanyFilterChange();">
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <div for="ddlFilterDepartment">ชื่อหน่วยงาน:</div>
                            </div>
                            <div class="col">
                                <select class="form-control form-select"
                                        id="ddlFilterDepartment"
                                        onchange="LoadDepartmentFilterChange();">
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <div for="ddlFilterStatus">สถานะใช้งาน:</div>
                            </div>
                            <div class="col">
                                <select class="form-control form-select"
                                        id="ddlFilterStatus"
                                        onchange="LoadStatusFilterChange();">
                                    <option value="">ทั้งหมด</option>
                                    <option value="1" selected="selected">Active</option>
                                    <option value="0">Inactive</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="main-content-pt3 mt-2">
                <div class="row">
                    <div class="full-panel">
                        <div class="white-card">
                            <!-- =======  Filter - Display  = End  ========================== -->
                            <div class="main-table-preparation-scroll main-table-master">
                                <table id="dtCashTypeLists" class="masterDataTable data-table-master"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- =======  Data-Table  = End    ========================== -->
<div style="display:none;">
    <input type="text" id="rowItemSelected" value="" style="display:none;" />
    <input type="text" id="modeSave" value="" style="display:none;" />
</div>

<!-- =======  Modal View Detail  = Start    ========================== -->
<div class="modal fade" id="ViewItemDetailModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title" id="titleViewModalLabel">รายละเอียด</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formViewCashPointDetail">
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="txtViewCbBcdCode" class="col-form-label">รหัสสัญญา:</label>
                            </div>
                            <div class="col-sm-9">
                                <input type="text" readonly class="form-control-plaintext" id="txtViewCbBcdCode" value="">
                            </div>
                        </div>
                    </div> 
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="txtViewCompanyName" class="col-form-label">ชื่อบริษัท:</label>
                            </div>
                            <div class="col-sm-9">
                                <input type="text" readonly class="form-control-plaintext" id="txtViewCompanyName" value="">
                            </div>
                        </div>
                    </div> 
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="txtViewDepartmentName" class="col-form-label">ชื่อหน่วยงาน:</label>
                            </div>
                            <div class="col-sm-9">
                                <input type="text" readonly class="form-control-plaintext" id="txtViewDepartmentName" value="">
                            </div>
                        </div>
                    </div> 
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="txtViewStartDate" class="col-form-label">วันที่มีผล:</label>
                            </div>
                            <div class="col-sm-9">
                                <input type="text" readonly class="form-control-plaintext" id="txtViewStartDate" value="">
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="txtViewEndDate" class="col-form-label">วันที่สิ้นสุด:</label>
                            </div>
                            <div class="col-sm-9">
                                <input type="text" readonly class="form-control-plaintext" id="txtViewEndDate" value="">
                            </div>
                        </div>
                    </div>                    
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="spanViewIsSendUnsortCC" class="col-form-label">มีการส่งมอบ รับมอบ:</label>
                            </div>
                            <div class="col-sm-9">
                                <span id="spanViewIsSendUnsortCC" style="" class="badge badge-inactive"></span>
                            </div>
                        </div>
                    </div>                    
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="spanViewIsPrepareCentral" class="col-form-label">Prepare กลาง:</label>
                            </div>
                            <div class="col-sm-9">
                                <span id="spanViewIsPrepareCentral" style="" class="badge badge-inactive"></span>
                            </div>
                        </div>
                    </div>                    
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-sm-3">
                                <label for="spanViewStatus" class="col-form-label">สถานะใช้งาน:</label>
                            </div>
                            <div class="col-sm-9">
                                <span id="spanViewStatus" style="" class="badge badge-inactive"></span>
                            </div>
                        </div>
                    </div>
                    
                </form>
            </div>
            <div class="modal-footer justify-content-end">
                <button type="button" class="btn btn-blue" id="btnEditDetail"><i class="bi bi-pencil-fill" fill="currentColor"></i> แก้ไข </button>
            </div>
        </div>
    </div>
</div>
<!-- =======  Modal View Detail  = End    ========================== -->

<!-- =======  Modal Create & Edit  = Start    ========================== -->

<div class="modal fade" id="addOrEditItemModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title" id="titleModalLabel">เพิ่มข้อมูล</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formCreateCashPoint">
                     
                    <div class="mb-3">
                        <span class="text-muted small char-counter float-end">0/10</span>
                        <label class="form-label" for="txtCbBcdCode">รหัสสัญญา</label><span class="text-danger"> * </span>
                        <input class="form-control" id="txtCbBcdCode" autocomplete="off" required maxlength="10" />
                        <div class="invalid-feedback">this field is required! </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="ddlCompany">ชื่อบริษัท</label><span class="text-danger"> * </span>
                        <select class="form-control form-select" id="ddlCompany" required>
                        </select>
                        <div class="invalid-feedback">this field is required! </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="ddlDepartment">ชื่อหน่วยงาน</label><span class="text-danger"> * </span>
                        <select class="form-control form-select" id="ddlDepartment" required>
                        </select>
                        <div class="invalid-feedback">this field is required! </div>
                    </div>
                    <div class="mb-3 row">
                        <div class="col-sm-6">
                            <label class="form-label" for="txtStartDate">วันที่มีผล <span class="text-danger"> * </span></label>
                            <div class="input-group">
                                <input class="form-control" id="txtStartDate" autocomplete="off" required />
                                <span class="input-group-text"><i class="bi bi-calendar-check"></i></span>
                            </div>
                            <div class="invalid-feedback">this field is required! </div>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label" for="txtEndDate">วันที่สิ้นสุด <span class="text-danger"> * </span></label>
                            <div class="input-group">
                                <input class="form-control" id="txtEndDate" autocomplete="off" required />
                                <span class="input-group-text"><i class="bi bi-calendar-check"></i></span>
                            </div>
                            <div class="invalid-feedback">this field is required! </div>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <div class="col-sm-6">
                            <label class="form-check-label" for="checkIsSendUnsortCC">มีการส่งมอบ รับมอบ</label>
                        </div>
                        <div class="col-sm-6 row">
                            <div class="col-sm-10" style="text-align:end !important;">
                                <span id="spanIsSendUnsortCC" class="badge">No</span>
                            </div>
                            <div class="col-sm-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input large-switch" type="checkbox" value="" id="checkIsSendUnsortCC">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <div class="col-sm-6">
                            <label class="form-check-label" for="checkIsPrepareCentral">Prepare กลาง</label>
                        </div>
                        <div class="col-sm-6 row">
                            <div class="col-sm-10" style="text-align:end !important;">
                                <span id="spanIsPrepareCentral" class="badge">No</span>
                            </div>
                            <div class="col-sm-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input large-switch" type="checkbox" value="" id="checkIsPrepareCentral">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <div class="col-sm-6">
                            <label class="form-check-label" for="checkIsActive">ตั้งค่าสถานะการใช้งาน</label>
                        </div>
                        <div class="col-sm-6 row">
                            <div class="col-sm-10" style="text-align:end !important;">
                                <span id="spanStatus" class="badge">Inactive</span>
                            </div>
                            <div class="col-sm-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input large-switch" type="checkbox" value="" id="checkIsActive">
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-gray" data-bs-dismiss="modal" id="btnCancel"><i class="bi bi-x-circle" fill="currentColor"></i> ยกเลิก </button>
                <button type="button" class="btn btn-blue" id="btnSave"><i class="bi bi-plus-circle" fill="currentColor"></i> บันทึก </button>
            </div>
        </div>
    </div>
</div>
<!-- =======  Modal Create & Edit  = End    ========================== -->
<!-- =======  Modal Deleted  = Start    ========================== -->
<div class="modal fade" id="confirmSaveModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title" id="titleSaveModalLabel">ยืนยันการบันทึกข้อมูล</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ต้องการยืนยันเพื่อทำการบันทึกข้อมูลหรือไม่ ?
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-gray" data-bs-dismiss="modal" id="btnConfirmClose"><i class="bi bi-x-circle" fill="currentColor"></i> ยกเลิก </button>
                <button type="button" class="btn btn-green" id="btnConfirmSave"><i class="bi bi-plus-circle" fill="currentColor"></i> ยืนยัน </button>
            </div>
        </div>
    </div>
</div>
<!-- =======  Modal Deleted  = End    ========================== -->
@section CustomStyle {
    <link rel="stylesheet" href="@Url.Content("~/css/helpers/bss-datatable-style.css")" />
}
@section Scripts {
    <script src="@Url.Content("~/js/helpers/serverside.datatable.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/masterdata/MasterCompanyDepartment.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/master/admin.js")" asp-append-version="true"></script>
}
