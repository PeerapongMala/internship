{
  "name": "BSS Full Project",

  // docker-compose.yml              = base config (image, network, workspace)
  // docker-compose.devcontainer.yml = Claude credentials mount (auto-generated by pre-start.sh)
  "dockerComposeFile": ["docker-compose.yml", "docker-compose.devcontainer.yml"],
  "service": "app",
  "workspaceFolder": "/workspaces/project",
  "overrideCommand": true,

  // แก้ "unsafe repository" — env vars ทำงานก่อนทุก lifecycle script และ extension
  "containerEnv": {
    "GIT_CONFIG_COUNT": "1",
    "GIT_CONFIG_KEY_0": "safe.directory",
    "GIT_CONFIG_VALUE_0": "*",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },

  // รัน pre-start.sh บน HOST ก่อนสร้าง container:
  //   ตรวจ OS → overwrite docker-compose.devcontainer.yml ด้วย mount path จริง
  "initializeCommand": ".devcontainer\\pre-start.cmd || sh .devcontainer/pre-start.sh",

  // [MCP Server] เชื่อมต่อ Figma Dev Mode MCP server (รันอัตโนมัติเมื่อเปิด Figma desktop + Dev Mode):
  //   Figma desktop เปิด server ที่ http://127.0.0.1:3845/mcp (Windows host)
  //   เพราะใช้ network_mode: host → container เข้าถึง localhost ได้โดยตรง:
  //   claude mcp add --transport http figma-dev-mode-mcp-server http://127.0.0.1:3845/mcp
  //   (post-start.sh ทำอัตโนมัติให้แล้ว)

  // เครื่องมือเสริมที่ติดตั้งเพิ่มใน container
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},          // Node.js (สำหรับ frontend tooling)
    "ghcr.io/devcontainers/features/java:1": {            // Java (สำหรับ dotnet-sonarscanner)
      "version": "21",
      "jdkDistro": "ms"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {} // Claude Code CLI
  },

  // รัน post-start.sh ทุกครั้งที่ container start:
  //   - ตรวจ Claude credentials mount
  //   - เชื่อม Figma MCP อัตโนมัติ (ข้ามถ้าล้มเหลว)
  "postStartCommand": "bash .devcontainer/post-start.sh",

  "customizations": {
    "vscode": {
      // Extensions ที่ติดตั้งอัตโนมัติใน container
      "extensions": [
        "ms-dotnettools.csdevkit",    // C# Dev Kit: จำเป็นสำหรับ debug type "coreclr"
        "bierner.markdown-mermaid",   // แสดง Mermaid diagram ใน Markdown preview
        "usernamehw.errorlens"        // แสดง error/warning inline ในโค้ด
      ],
      "settings": {
        // เปิด Markdown preview เป็น default editor สำหรับไฟล์ .md
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },

        // ให้ Source Control แยกแสดง submodule (backend/frontend) เป็น repo แยก
        "git.detectSubmodules": true,
        "git.detectSubmodulesLimit": 10,

        // ปิด popup "Multiple Visual Studio Solution files"
        // เพราะ project นี้มี 2 .sln (BSS_API.sln + BSS_WEB.sln)
        // launch.json จัดการ build แยกอยู่แล้ว ไม่ต้องเลือก solution
        "dotnet.defaultSolution": "disable"
      }
    }
  }
}
