@{
    var roleName = Context.Request.Cookies["operation_setting_name"];
    var firstName = Context.Request.Cookies["user_first_name"];
    var lastName = Context.Request.Cookies["user_last_name"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BSS_WEB</title>
    <link rel="stylesheet" href="@Url.Content("~/lib/bootstrap/dist/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/datatables.net/css/dataTables.bootstrap5.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/datatables.net/css/responsive.bootstrap5.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/select2-plugins/css/select2.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/select2-plugins/css/select2-bootstrap-5-theme.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/bootstrap-icons/font/bootstrap-icons.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/toastr-notifications/css/toastr.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/sweetalert2/css/sweetalert2.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/bootstrap-5-datepicker/css/jquery.datetimepicker.css")" />
    <link rel="icon" href="@Url.Content("~/favicon.ico")" type="image/x-icon">

    <!--end::Layout Skins -->
    <!-- ================== BEGIN HELPERS CSS STYLE ================== -->
    @*     <link rel="stylesheet" href="~/css/helpers/bss-theme.css" /> *@
    <link rel="stylesheet" href="@Url.Content("~/css/Style.css")" asp-append-version="true" />
    <!-- ================== END HELPERS CSS STYLE ================== -->
    @await RenderSectionAsync("CustomStyle", required: false)
</head>
<body class="@ViewData["BodyClass"]" data-root-path="@Url.Content("~/")" path-base-bss="@BSS_WEB.Helpers.AppConfig.PathBase">
    <partial name="_PageLoader" />
    <div class="pattern-left"></div>
    <div class="pattern-right"></div>


    @{
        // กำหนด Logic การเลือกสี — ใช้ ViewData["NavColorClass"] ถ้ามี (จาก Controller)
        var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
        var navColorClass = ViewData["NavColorClass"]?.ToString();

        if (string.IsNullOrEmpty(navColorClass))
        {
            navColorClass = "nav-default"; // สีเริ่มต้น
            if (actionName.Contains("Register")) { navColorClass = "nav-orange"; }
            else if (actionName.Contains("UnsortCANonMember")) { navColorClass = "nav-purple"; }
            else if (actionName.Contains("UnsortCAMember")) { navColorClass = "nav-green"; }
            else if (actionName.Contains("UnsoftCC")) { navColorClass = "nav-orange"; }
            else if (actionName.Contains("Unfit")) { navColorClass = "nav-blue-light"; }
        }
    }

    
   <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bot-navbar box-shadow mb-3 shadow-sm @navColorClass">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <img src="@Url.Content("~/images/logo-bss.svg")" width="40" height="40" class="me-2" alt="Logo" />
                <div class="brand-text-group">
                    <div class="brand-label-main">ธนาคารแห่งประเทศไทย</div>
                    <div class="brand-label-sub">ระบบตรวจสอบการนับคัดธนบัตร <span class="version-text">Version 1.0.0</span></div>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" 
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-center" id="mainNav">
                @await Component.InvokeAsync("Menu")
            </div>

            <div class="d-flex align-items-center">

                    <div>
                        <h6 id="user-name-display" class="d-inline-block align-top">@firstName @lastName</h6>
                        <span id="span-role-display" class="d-inline-block align-bottom">( @roleName )</span>
                    </div>


                <div class="notification-wrapper me-3" style="display:none;">
                    <i class="bi bi-bell-fill"></i>
                    <span class="notification-badge">3</span>
                </div>

                <div class="dropdown" id="dropdownUser">
                    <a href="#" id="linkUser" data-bs-toggle="dropdown" aria-expanded="false" class="text-white">
                        <i class="bi bi-person-circle fs-4"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="linkUser">
                        <li class="dropdown-header border-bottom mb-2">
                                <div><strong>@firstName @lastName</strong></div>
                             
                        </li>
                            <li class="dropdown-header border-bottom mb-2">
                                <small class="text-muted">@roleName</small>
                            </li>
                        <li>
                            <a class="dropdown-item text-danger" href="#" id="btnLogOut">
                                <i class="bi bi-box-arrow-right me-2"></i> ออกจากระบบ
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>
</header>
    <div class="container-fluid">
        @RenderBody()
    </div>
    <!-- =======  Modal Confirm  = Start    ========================== -->
    <!-- Modal Confirm Logout: ยืนยันการออกจากระบบ -->
    <div class="modal fade" id="confirmLogoutModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body text-center py-5">
                    <div class="mb-4">
                        <div class="modal-warning-title">
                            <i class="bi bi-exclamation-diamond-fill"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-3">ออกจากระบบ</h3>
                    <h6 class="mb-4">คุณแน่ใจหรือไม่ที่ต้องการออกจากระบบ</h6>
                </div>
                <div class="modal-footer d-flex justify-content-center gap-2">
                    <button class="btn btn-gray px-4" data-bs-dismiss="modal" id="btnConfirmClose">ยกเลิก</button>
                    <button class="btn btn-red px-4" id="btnConfirmLogout">ยืนยัน</button>
                </div>
            </div>
        </div>
    </div>
    <!-- =======  Modal Confirm  = End    ========================== -->

    @*     <footer class="border-top footer text-muted">
    <div class="container">
    &copy; 2568 - BSS System.
    </div>
    </footer> *@
    <!--end::Global Theme Bundle -->
    <!--end::Page Scripts -->
    <!-- ================== BEGIN HELPERS JS ================== -->
    <script src="@Url.Content("~/lib/jquery/dist/jquery.min.js")"></script>
    <script src="@Url.Content("~/lib/bootstrap/dist/js/bootstrap.bundle.min.js")"></script>
    <script src="@Url.Content("~/lib/select2-plugins/js/select2.full.min.js")"></script>
    <script src="@Url.Content("~/lib/datatables.net/js/jquery.dataTables.min.js")"></script>
    <script src="@Url.Content("~/lib/datatables.net/js/dataTables.bootstrap5.min.js")"></script>
    <script src="@Url.Content("~/lib/datatables.net/js/dataTables.responsive.min.js")"></script>
    <script src="@Url.Content("~/lib/datatables.net/js/responsive.bootstrap5.min.js")"></script>
    <script src="@Url.Content("~/lib/toastr-notifications/js/toastr.min.js")"></script>
    <script src="@Url.Content("~/lib/sweetalert2/js/sweetalert2.all.min.js")"></script>
    <script src="@Url.Content("~/lib/bootstrap-5-datepicker/js/jquery.datetimepicker.full.min.js")"></script>
    <script src="@Url.Content("~/js/helpers/thai.datepicker.js")"></script>
    <script src="@Url.Content("~/js/helpers/linq.min.js")"></script>
    <script src="@Url.Content("~/js/helpers/numeral.min.js")"></script>
    <script src="@Url.Content("~/js/helpers/app-constants.js")"></script>
    <script src="@Url.Content("~/js/helpers/master-dropdown.js")"></script>
    <script src="@Url.Content("~/js/helpers/notification.js")"></script>
    <script src="@Url.Content("~/js/helpers/bss-common.js")"></script>
    <script src="@Url.Content("~/js/helpers/bss-ajax.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/helpers/bss-layout.js")"></script>
    <!-- ================== END HELPERS JS ================== -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

