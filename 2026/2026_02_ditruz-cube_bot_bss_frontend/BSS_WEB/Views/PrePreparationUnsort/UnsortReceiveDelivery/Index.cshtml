@model BSS_WEB.Views.PrePreparationUnsort.UnsortReceiveDelivery.IndexModel

@{
    var roleName = Context.Request.Cookies["operation_setting_name"];
    var firstName = Context.Request.Cookies["user_first_name"];
    var lastName = Context.Request.Cookies["user_last_name"];
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "UnsortReceiveDelivery";
}

<link rel="stylesheet" href="@Url.Content("~/css/master/all.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/preparation/unsortCC.css")" asp-append-version="true" />

<input type="hidden" id="currentSendUnsortId" value="" />

<div class="main-wrapper">
    <div class="sub-wrapper">
        <div class="layout">

            <div class="main-title">
                <div class="title-left">
                    <div class="title-section">
                        <h1>รับมอบ UNSORT CC</h1>
                    </div>
                </div>
                <div class="title-right">
                    <div class="header-info-compact">
                        <div class="info-line">
                            <span class="label">Supervisor ส่งมอบ:</span>
                            <span id="senderName" class="value"></span>
                        </div>
                        <div class="info-line">
                            <span class="label">Supervisor รับมอบ:</span>
                            <span id="receiverName" class="value">@firstName @lastName</span>
                        </div>
                        <div class="info-line">
                            <span class="label">Date:</span>
                            <span id="deliveryDateText" class="value">21/7/2568 16:26</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="main-content-wrapper mb-2">
                <div class="white-card mb-2">
                    <div class="row g-3 align-items-center row-cols-1 row-cols-lg-3">
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label class="form-label fw-semibold mb-0 text-nowrap">สแกนรหัสใบนำส่ง: </label>
                                </div>
                                <div class="col">
                                    <input type="text" id="deliveryInput" class="form-control" autocomplete="off" maxlength="20">
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label class="form-label fw-semibold mb-0 text-nowrap">วันที่ส่งมอบ: </label>
                                </div>
                                <div class="col">
                                    <span id="deliveryDateTextt" class="info-value-text ms-2">-</span>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label class="form-label fw-semibold mb-0 text-nowrap">สถานะ: </label>
                                </div>
                                <div class="col">
                                    <span id="overallStatusBadge">-</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="main-content-pt4">
                    <div class="row">
                        <div class="left-panel-pt4">
                            <div class="white-card">
                                <div class="card-title">รายการอนุมัติไม่รับมอบ / รับมอบ</div>
                                <div id="containerScroll" class="main-table-preparation-scroll">
                                    <table class="data-table preparationREGISTER_UNSORT_CC_RCV_01">
                                        <thead>
                                            <tr>
                                                <th>บาร์โค้ดภาชนะ</th>
                                                <th>จำนวน (มัด)</th>
                                            </tr>
                                        </thead>
                                        <tbody id="containerListBody"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="right-panel-pt4">

                            <div class="white-card">
                                <div id="dvBtnExecute" class="d-flex flex-column justify-content-center align-items-center gap-2 p-2 h-100">

                                    <button class="btn-action-horizontal btn-green w-100 fs-5 p-4" onclick="openReceiveModal()" disabled>
                                        <i class="bi bi-check-circle-fill"></i> <span>รับมอบ</span>
                                    </button>
                                    <hr class="w-100 border-secondary opacity-50" />
                                    <button class="btn-action-horizontal btn-red w-100 fs-5 p-4" id="btnRejectReceive" onclick="handleReject()" disabled>
                                        <i class="bi bi-x-circle-fill"></i> <span>ไม่รับมอบ</span>
                                    </button>

                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>

            <div class="main-content-pt4">

                <div class="row-sub">
                    <div class="left-panel-pt4">
                        <div class="white-card">

                            <div class="table-controls">
                                <div class="wc-header-left">
                                    <span class="card-title">รายการรับมอบ UNSORT CC</span>
                                </div>
                                <div class="wc-header-right">
                                    <button id="btnReturnSelected" class="btn-outline-blue d-none" onclick="handleReturnSelected()">
                                        <i class="bi bi-arrow-return-left"></i> <span>ส่งคืนข้อมูล <span id="selectedCount">0</span> รายการ</span>
                                    </button>
                                </div>
                            </div>

                            <div id="tableBodyScroll" class="main-table-preparation-scroll">
                                <table class="data-table preparationREGISTER_UNSORT_CC_RCV_02">
                                    <thead>
                                        <tr>
                                            <th><input type="checkbox" id="checkAllHistory" onclick="toggleCheckAll(this)"></th>
                                            <th>รหัสใบนำส่ง</th>
                                            <th>วันที่ส่งมอบ</th>
                                            <th>วันที่รับมอบ</th>
                                            <th>หมายเหตุการส่งคืน</th>
                                            <th>สถานะ</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="receiveDeliveryTableBody"></tbody>
                                </table>
                            </div>

                        </div>
                    </div>

                    <div class="right-panel-pt4">
                        <div class="white-card">
                            <div class="table-controls">
                                <div class="wc-header-left">
                                    <span class="card-title">ข้อมูลตามใบนำส่งที่เลือก</span>
                                </div>
                                <div class="wc-header-right">
                                </div>
                            </div>
                            <div class="main-table-preparation-scroll">
                                <table class="data-table preparationREGISTER_UNSORT_CC_RCV_03">
                                    <thead>
                                        <tr>
                                            <th>บาร์โค้ดภาชนะ</th>
                                            <th>จำนวน (มัด)</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="deliveryDataBody">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="mt-2"></div>
                        <div class="white-card">
                            <div class="table-controls">
                                <div class="wc-header-left">
                                    <span class="card-title">ข้อมูลตามบาร์โค้ดภาชนะที่เลือก</span>
                                </div>
                                <div class="wc-header-right">
                                </div>
                            </div>
                            <div class="main-table-preparation-scroll">
                                <table class="data-table preparationREGISTER_UNSORT_CC_RCV_04">
                                    <thead>
                                        <tr>
                                            <th>ธนาคาร</th>
                                            <th>ชนิดราคา</th>
                                            <th>Un-Prepare (มัด)</th>
                                            <th>Prepare (มัด)</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="chooseContainerBody">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="DeleteModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3">ลบข้อมูล 1 รายการ</h3>
                <h6 class="mb-4">คุณแน่ใจหรือไม่ที่จะลบข้อมูลนี้</h6>
            </div>

            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-red px-4" onclick="confirmDelete()">ยืนยัน</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ReturnModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>

                <h4 class="fw-bold mb-3">ส่งคืนข้อมูล <span id="returnQtyText">1</span> รายการ</h4>
                <h6 class="mb-4">คุณแน่ใจหรือไม่ที่ต้องการส่งคืนข้อมูลนี้?</h6>

                <div class="px-3 text-start">
                    <span class="form-label small">หมายเหตุ:</span>
                    <div class="has-validation">
                        <input type="text" id="returnNote" class="form-control form-control-sm" placeholder="" autocomplete="off" maxlength="100" required>
                        <div id="returnNoteFeedback" class="invalid-feedback">
                            กรุณาระบุหมายเหตุ
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-red px-4" onclick="confirmReturn()">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ReceiveModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-body text-center p-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>

                <h3 class="fw-bold mb-3">ยืนยันการรับมอบ</h3>
                <h6 class="mb-4">กรุณาตรวจสอบความถูกต้องของรายการ ก่อนกดยืนยัน</h6>
            </div>

            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-green" onclick="executeReceive()">ยืนยัน</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="RejectModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-body text-center p-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>

                <h3 class="fw-bold mb-3">ไม่รับมอบ <span id="rejectQtyText" class="text-danger">1</span> รายการ</h3>
                <h6 class="mb-4">คุณแน่ใจหรือไม่ที่ไม่รับมอบข้อมูลนี้</h6>

                <div class="px-3 text-start">
                    <span class="form-label small">หมายเหตุ:</span>
                    <div class="has-validation">
                        <input type="text" id="rejectNote" class="form-control form-control-sm" placeholder="" maxlength="100" autocomplete="off" required>
                        <div id="rejectNoteFeedback" class="invalid-feedback">
                            กรุณาระบุหมายเหตุ
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-red" onclick="confirmReject()">ยืนยัน</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="EditBarcodeModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem;">แก้ไขข้อมูลธนบัตร</h5>
            </div>

            <div class="modal-body py-3">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold mb-1">บาร์โค้ดภาชนะ</label>
                        <input type="text" id="editContainerBarcode" class="form-control bg-light border-0"
                               readonly style="height: 45px; color: #6c757d;">
                    </div>

                    <div class="col-12">
                        <label class="form-label small fw-semibold mb-1">ธนาคาร</label>
                        <input type="text" id="editBankText" class="form-control bg-light border-0"
                               readonly style="height: 45px; color: #6c757d;">
                    </div>

                    <div class="col-12">
                        <label class="form-label small fw-semibold mb-1">ชนิดราคา</label>
                        <input type="text" id="editDenomText" class="form-control bg-light border-0"
                               readonly style="height: 45px; color: #6c757d;">
                    </div>

                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">จำนวนมัด</label>
                        <input type="text" id="oldUnPrepare" class="form-control bg-light border-0"
                               readonly style="height: 45px; color: #6c757d;">
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">จำนวนมัด</label>
                        <input type="number" id="newUnPrepare" class="form-control border-secondary-subtle text-end"
                               placeholder="0" style="height: 45px; font-weight: 500;" min="0" oninput="this.value = this.value.replace(/[^0-9]/g, '');validateMax(this);">
                        <div id="unPrepareError" class="text-danger mt-1" style="display: none; font-size: 11px;">
                            * ระบุจำนวนมัดให้ถูกต้อง (0-20)
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-gray" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnSaveEdit" class="btn btn-green">บันทึก</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="SuccessModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-success-title">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3">สำเร็จ!</h3>
                <h6 class="mb-4">ส่งคืนข้อมูลการส่งมอบสำเร็จ</h6>
            </div>
            <div class="modal-footer justify-content-center">
                <button class="btn btn-green" onclick="closeAllModals()">
                    <i class="bi bi-check-lg"></i> ตกลง
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ErrorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center p-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>

                <h3 class="fw-bold mb-3">การแจ้งเตือน</h3>
                <h6 class="mb-4" id="errorMessage">ไม่พบข้อมูลรหัสใบนำส่งที่สแกน <br> กรุณาตรวจสอบรหัสอีกครั้ง</h6>
            </div>
            <div class="modal-footer d-flex justify-content-center">
                <button type="button" class="btn btn-blue px-4" data-bs-dismiss="modal">ตกลง</button>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="@Url.Content("~/js/registerUnsortCC/UnsortReceiveDelivery.js")" asp-append-version="true"></script>
}