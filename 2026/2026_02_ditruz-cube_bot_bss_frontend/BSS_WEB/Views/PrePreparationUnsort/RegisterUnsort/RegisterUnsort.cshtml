@model BSS_WEB.Views.Preparation.PreparationUnsoftCC.IndexModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "PrePreparationUnsortCC";
}

<link rel="stylesheet" href="@Url.Content("~/css/master/all.css")" asp-append-version="true" />
<link rel="stylesheet" href="@Url.Content("~/css/preparation/unsortCC.css")" asp-append-version="true" />

@Html.AntiForgeryToken()
<div class="main-wrapper">
    <div class="sub-wrapper">
        <div class="layout">

            <div class="main-title mb-2">
                <div class="title-left">
                    <div class="title-section">
                        <h1>ลงทะเบียน UNSORT CC</h1>
                    </div>
                </div>
                <div class="title-right"> 
                </div>
            </div>

            <input type="hidden" id="currentDepartmentId" value="@User.FindFirst("DepartmentID")?.Value" />
            <!-- Main Content -->
            <div class="main-content-pt2 main-content-pt2-h4 mb-2">
                <div class="row">
                    <div class="left-panel-pt2">
                        <div class="white-card">
                            <div class="card-title">รายการภาชนะ</div>
                            <div id="containerScroll" class="main-table-preparation-scroll">
                                <table class="data-table preparationREGISTER_UNSORT_CC">
                                    <thead>
                                        <tr>
                                            <th>บาร์โค้ดภาชนะ</th>
                                            <th>วันที่ลงทะเบียน</th>
                                            <th>หมายเหตุการส่งคืน</th>
                                            <th>สถานะ</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableContainer"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="right-panel-pt2">

                        <div class="white-card">

                            <div class="d-flex w-100 gap-3 mb-3">
                                <div class="w-50">
                                    <div class="step-label">สแกนบาร์โค้ดภาชนะ</div>
                                    <input type="text" id="txtScanContainerCode" maxlength="7" class="form-control" placeholder="สแกนบาร์โค้ดภาชนะ" autocomplete="off" />
                                </div>

                                <div class="w-50">
                                    <div class="step-label">ธนาคาร</div>
                                    <select class="form-select" id="bankName">
                                        <option value="">-- กรุณาเลือก --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="w-100 mb-3">
                                    <div class="step-label d-block">ชนิดราคา</div>
                                <div id="banknoteContainer" class="banknote-item"></div>
                            </div>
                            <div class="d-flex w-100 gap-3">
                                <div class="flex-fill">
                                    <div class="step-label">จำนวนมัด</div>
                                    <input type="number" id="txtBundleCount" class="form-control" placeholder="กรอกจำนวนมัด" />
                                </div>
                                <div class="flex-fill">
                                    <div class="step-label">&nbsp;</div>
                                    <button id="btnAddUnsortCC" class="btn-green w-100" disabled>
                                        <i class="bi bi-chevron-double-down me-2"></i>
                                        เพิ่มธนบัตร
                                        <i class="bi bi-chevron-double-down ms-2"></i>
                                    </button>
                                </div>
                            </div>

                        </div>

                    </div>
                </div>
            </div>

            <div class="main-content-pt3 mt-2">
                <div class="row">
                    <div class="full-panel">
                        <div class="white-card">
                            <div class="table-controls">
                                <div class="wc-header-left">
                                    <span class="card-title"> รายการลงทะเบียนธนบัตรตามบาร์โค้ดภาชนะที่เลือก </span>
                                </div>
                                <div class="wc-header-right">
                                    <span class="card-title">จำนวนมัด: <strong id="totalBundle" class="status-count">0</strong> มัด</span>
                                </div>
                            </div>

                            <div id="tableBodyScroll" class="main-table-preparation-scroll">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>ธนาคาร</th>
                                            <th>ชนิดราคา</th>
                                            <th>จำนวน(มัด)</th>
                                            <th>วันที่ลงทะเบียน</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

                <div class="row">
                <div class="btn-wrapper">
                    <button class="btn-blue" id="confirmRegisterUnsort" onclick="ConfirmRegisterUnsort()" disabled>ยืนยัน</button>
                    </div>
                </div>

        </div>
    </div>
</div>

@* ลบภาชนะ *@
<div class="modal fade" id="DeleteModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="text-black fw-bold mb-3">ลบข้อมูลบาร์โค้ดภาชนะ</h3>
                <h6 class="text-muted mb-4">คุณแน่ใจหรือไม่ที่ต้องการลบข้อมูลนี้</h6>
            </div>
            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-red px-4" onclick="confirmDelete()">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

@* ลบธนบัตร *@
<div class="modal fade" id="DeleteBankNoteModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="text-black fw-bold mb-3">ลบข้อมูลธนบัตร</h3>
                <h6 class="text-muted mb-4">คุณแน่ใจหรือไม่ที่ต้องการลบข้อมูลนี้</h6>
            </div>
            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-red px-4" onclick="confirmDeleteBankNote()">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

@* ลบภาชนะสำเร็จ *@
<div class="modal fade" id="deleteSuccessModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-success-title">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3">สำเร็จ!</h3>
                <h6 class="mb-4">ลบข้อมูลสำเร็จ</h6>
            </div>
            <div class="modal-footer justify-content-center">
                <button class="btn btn-success px-5" onclick="closeAllModals()">
                    <i class="bi bi-check-lg"></i> ตกลง
                </button>
            </div>
        </div>
    </div>
</div>

@* แก้ไขภาชนะ *@
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">แก้ไขบาร์โค้ดภาชนะ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">บาร์โค้ดภาชนะเดิม</label>
                            <input type="text" class="form-control bg-light" id="oldContainer" disabled>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">บาร์โค้ดภาชนะใหม่</label>
                            <input type="text" class="form-control" id="editContainer" placeholder="กรอกบาร์โค้ดภาชนะใหม่">
                            <div class="invalid-feedback">
                                กรุณากรอกบาร์โค้ดภาชนะ
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button class="btn btn-gray" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-green" onclick="updateContainer()">บันทึก</button>
            </div>
        </div>
    </div>
</div>

@* แก้ไขธนบัตร *@
<div class="modal fade" id="editBankNoteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">แก้ไขรายละเอียด</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId">

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="form-label">บาร์โค้ดภาชนะ</label>
                        <input type="text" class="form-control bg-light" id="oldContainerBankNote" disabled>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-12" id="sectionViewBank">
                        <label class="form-label">ธนาคาร</label>
                        <input type="text" class="form-control bg-light" id="oldBankNoteFull" disabled>
                    </div>
                    <div class="col-md-6" id="sectionOldBank">
                        <label class="form-label">ธนาคาร</label>
                        <input type="text" class="form-control bg-light" id="oldBankNoteHalf" disabled>
                    </div>
                    <div class="col-md-6" id="sectionEditBank">
                        <label class="form-label">แก้ไขธนาคาร</label>
                        <select class="form-select" id="editBankNote">
                            <option value="">-- เลือกธนาคาร --</option>
                        </select>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-12" id="sectionViewPrice">
                        <label class="form-label">ชนิดราคา</label>
                        <input type="text" class="form-control bg-light" id="oldPriceFull" disabled>
                    </div>
                    <div class="col-md-6" id="sectionOldPrice">
                        <label class="form-label">ชนิดราคา</label>
                        <input type="text" class="form-control bg-light" id="oldPriceHalf" disabled>
                    </div>
                    <div class="col-md-6" id="sectionEditPrice">
                        <label class="form-label">แก้ไขชนิดราคา</label>
                        <div class="d-flex gap-2">
                            <select class="form-select" id="editPriceType" onchange="updatePriceTypeBadge(this.value)">
                                <option value="">-- เลือกชนิดราคา --</option>
                            </select>
                            <span id="priceTypeBadge" class="qty-badge qty-100" style="min-width: 60px; display: flex; align-items: center; justify-content: center;">-</span>
                        </div>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">จำนวนมัด</label>
                        <input type="text" class="form-control bg-light" id="oldCountBundle" disabled>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">จำนวนมัด</label>
                        <input type="number" min="0" max="999" class="form-control" id="editoldCountBundle">
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button class="btn btn-gray" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-blue" id="btnSaveEditBankNote" onclick="updateBankNote()">บันทึก</button>
            </div>
        </div>
    </div>
</div>

@* ยืนยันการแก้ไขภาชนะ *@
<div class="modal fade" id="ConfirmEditContainerModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="text-black fw-bold mb-3">แก้ไขข้อมูลบาร์โค้ดภาชนะ</h3>
                <h6 class="text-muted mb-4">คุณแน่ใจหรือไม่ที่ต้องการแก้ไขข้อมูลนี้</h6>
            </div>
            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-red px-4" onclick="confirmUpdateContainer()">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

@* ยืนยันการแก้ไขธนบัตร *@
<div class="modal fade" id="ConfirmEditBankNoteModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="text-black fw-bold mb-3">แก้ไขข้อมูลธนบัตร</h3>
                <h6 class="text-muted mb-4">คุณแน่ใจหรือไม่ที่ต้องการแก้ไขข้อมูลนี้</h6>
            </div>
            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-red px-4" onclick="confirmUpdateBankNote()">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

@* แก้ไขสำเร็จ *@
<div class="modal fade" id="editSuccessModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-success-title">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3">สำเร็จ!</h3>
                <h6 class="mb-4">แก้ไขข้อมูลสำเร็จ</h6>
            </div>
            <div class="modal-footer justify-content-center">
                <button class="btn btn-success px-5" onclick="closeAllModals()">
                    <i class="bi bi-check-lg"></i> ตกลง
                </button>
            </div>
        </div>
    </div>
</div>


<!-- Modal error จากการ validate -->
<div class="modal fade" id="barcodeErrorModal" data-bs-backdrop="static" data-bs-keyboard="false"
     tabindex="-1" aria-labelledby="barcodeErrorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3" id="barcodeErrorModalLabel">การแจ้งเตือน</h3>
                <h6 class="mb-4" id="barcodeErrorMessageText">ข้อความผิดพลาด</h6>
            </div>
            <div class="modal-footer justify-content-center gap-2">
                <button type="button" class="btn btn-blue" data-bs-dismiss="modal">ตกลง</button>
            </div>
        </div>
    </div>
</div>

@* ยืนยันการลงทะเบียน *@
<div class="modal fade" id="confirmRegisterUnsortModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-warning-title">
                        <i class="bi bi-exclamation-diamond-fill"></i>
                    </div>
                </div>
                <h3 class="text-black fw-bold mb-3">ยืนยันการลงทะเบียน</h3>
                <h6 class="text-muted mb-4">คุณแน่ใจหรือไม่ที่ต้องการยืนยันข้อมูลนี้</h6>
            </div>
            <div class="modal-footer d-flex justify-content-center gap-2">
                <button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-blue px-4" onclick="doConfirmRegisterUnsort()">ยืนยัน</button>
            </div>
        </div>
    </div>
</div>

@* ลงทะเบียนสำเร็จ *@
<div class="modal fade" id="registerUnsortSuccessModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <div class="modal-success-title">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-3">สำเร็จ!</h3>
                <h6 class="mb-4">ลงทะเบียนข้อมูลสำเร็จ</h6>
            </div>
            <div class="modal-footer justify-content-center">
                <button class="btn btn-success px-5" onclick="window.location.reload()">
                    <i class="bi bi-check-lg"></i> ตกลง
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="@Url.Content("~/js/registerUnsortCC/RegisterUnsortCCNew.js")" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/main/bss-status-constants.js")"></script>
}