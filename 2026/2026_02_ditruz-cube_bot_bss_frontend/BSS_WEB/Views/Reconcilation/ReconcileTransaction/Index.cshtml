<!-- Modal 3: OTP Supervisor Verification -->
<div class="modal fade" id="otpReconcileModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title fw-bold">ยืนยัน OTP</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<div class="mb-3">
					<label class="form-label">เลือก Supervisor <span class="text-danger">*</span></label>
					<select class="form-select" id="reconcileSupervisorSelect">
						<option value="">- เลือก -</option>
					</select>
				</div>
				<div class="mb-3">
					<label class="form-label fw-bold">Supervisor กรอกรหัส OTP / Refcode : <span id="reconcileOtpRefcode">XXXXXX</span></label>
					<input type="text" id="reconcileOtpInput" class="form-control" placeholder="กรอกรหัส OTP 6 หลัก" maxlength="6" disabled>
					<small id="reconcileOtpErrorMsg" class="text-danger fw-bold"></small>
					<div class="d-flex align-items-center gap-3 mt-2">
						<button id="btnReconcileSendOtp" class="btn-blue btn-sm" onclick="sendReconcileOtp()">
							<i class="bi bi-envelope"></i> ส่งรหัส OTP
						</button>
						<span id="reconcileOtpTimer" class="text-danger fw-bold"></span>
					</div>
				</div>
			</div>
			<div class="modal-footer d-flex justify-content-between">
				<button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
				<button id="btnReconcileConfirmOtp" class="btn btn-green px-4" disabled onclick="submitReconcileOtp()">
					<i class="bi bi-check-circle"></i> ยืนยัน OTP
				</button>
			</div>
		</div>
	</div>
</div>

