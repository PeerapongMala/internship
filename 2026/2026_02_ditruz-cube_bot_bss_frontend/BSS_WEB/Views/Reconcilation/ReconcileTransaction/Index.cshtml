<!-- Modal 1: Edit Header Card -->
<div class="modal fade" id="editReconcileModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered modal-lg">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">แก้ไขข้อมูล Header Card</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<input type="hidden" id="editReconcileTranId">
				<div class="row g-4">
					<div class="col-md-6">
						<div class="mb-3">
							<label class="form-label">Header Card (เก่า)</label>
							<input type="text" class="form-control" id="editOldHeaderCard" disabled>
						</div>
					</div>
					<div class="col-md-6">
						<div class="mb-3">
							<label class="form-label">Header Card (ใหม่)</label>
							<input type="text" class="form-control" id="editNewHeaderCard">
						</div>
					</div>
				</div>
				<div class="mb-3">
					<label class="form-label">เหตุผล <span class="text-danger">*</span></label>
					<input type="text" class="form-control" id="editRemark" placeholder="ระบุเหตุผล">
				</div>
			</div>
			<div class="modal-footer d-flex justify-content-between">
				<button class="btn btn-gray px-4" data-bs-dismiss="modal">ยกเลิก</button>
				<button class="btn btn-blue px-4" onclick="submitEditReconcileTran()">บันทึก</button>
			</div>
		</div>
	</div>
</div>

