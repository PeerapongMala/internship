                        </tbody>
                    </table>
                </div>
            </div>



            <div id="pdf-viewer-container" style="width: 100%; height: 73%;margin-top:10px;">
                <iframe id="pdf-iframe" style="width: 100%; height: 100%; border: none; " title=""></iframe>
            </div>


        </div>
    </div>
</div>


<script src="@Url.Content("~/js/report/CashPointCenter.js")" asp-append-version="true"></script>
