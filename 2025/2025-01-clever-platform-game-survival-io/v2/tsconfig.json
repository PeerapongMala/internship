{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["src/assets/*"],
      "@public-assets": ["src/assets/public-assets-locations.ts"],
      "@class/*": ["src/Classes/*"],
      "@core-utils/*": ["src/utils/core-utils/*"]
    }
  },
  // "include": ["src", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "include": [
    "src",
    "**/*.ts",
    "**/*.tsx",
    "Assets",
    "config",
    "Scene",
    "Util",
    "declaration.d.ts"
  ],
  "exclude": ["node_modules", "vite.config.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
